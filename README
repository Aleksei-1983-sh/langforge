необходимо проверить 

apt-get update && apt-get install -y strace

strace -f -o /tmp/strace.log /usr/local/bin/englearn

strace -f -o /tmp/strace.log /app/tests/start_server.sh

tail -n 50 /tmp/strace.log

чтобы запустьть докер локально 
docker compose up --build

чтобы остановить 
 docker compose down -v

 проверить состояния контенеров 
docker compose ps

 чтобы зайти в какойто докер кантейнер например в ollama 
docker compose exec ollama sh
docker compose exec backend bash

я предлогаю реализовать полноценный путь запроса карточки чере сервер от клиенда ,

клиает отправляет запрос со словам (в роли клиента curl) > сервер понимает что надо обработать  в llm чтобы 
чтобы сгенереть карточку со словом  слова >> llm генерит карточку >>> сервер получает карточку и передает клиенту >>

проверка с клиента

docker compose exec client sh

curl http://backend:1234/api/generate_card \
  -H "Content-Type: application/json" \
  -d '{"word":"apple"}'

# регистрация
curl -i -X POST http://backend:1234/api/register \
  -H "Content-Type: application/json" \
  --cookie-jar cookies.txt \
  -d '{"username":"testuser","email":"test@example.com","password":"testpass"}'

# логин (cookie будет сохранён в cookies.txt)
curl -i -X POST http://backend:1234/api/login \
  -H "Content-Type: application/json" \
  --cookie-jar cookies.txt \
  --cookie cookies.txt \
  -d '{"username":"testuser","password":"testpass"}'

# проверить /api/me (отправляем cookie)
curl -i http://backend:1234/api/me --cookie cookies.txt





